&Тест
Процедура НаборОпций_РекурсивныйНаборОпций() Экспорт
	// Дано

	Поделка = ПолучитьПоделку();
	Поделка.ЗапуститьПриложение();

	// Когда

	Команда = Поделка.НайтиЖелудь("КомандаСРекурсивнымНабором");
	КонсольноеПриложение = Поделка.НайтиЖелудь("КонсольноеПриложение");

	ПараметрыКоманды = Новый Массив();
	ПараметрыКоманды.Добавить("recursive");
	ПараметрыКоманды.Добавить("--ibconnection");
	ПараметрыКоманды.Добавить("/recursive/db");
	ПараметрыКоманды.Добавить("--v8version");
	ПараметрыКоманды.Добавить("8.3.25");
	ПараметрыКоманды.Добавить("-o");
	ПараметрыКоманды.Добавить("/recursive/out");
	ПараметрыКоманды.Добавить("/recursive/file.cf");

	КонсольноеПриложение.Запустить(ПараметрыКоманды);

	// Тогда

	Ожидаем.Что(Команда.Результат[0], "Аргумент FILE").Равно("/recursive/file.cf");
	Ожидаем.Что(Команда.Результат[1], "Каталог выгрузки из расширенного набора").Равно("/recursive/out");
	Ожидаем.Что(Команда.Результат[2], "ibconnection из вложенного набора").Равно("/recursive/db");
	Ожидаем.Что(Команда.Результат[3], "v8version из вложенного набора").Равно("8.3.25");

КонецПроцедуры

&Тест
Процедура НаборОпций_СправкаСодержитОпцииИзНабора() Экспорт
	// Дано

	Поделка = ПолучитьПоделку();
	Поделка.ЗапуститьПриложение();

	// Когда

	КонсольноеПриложение = Поделка.НайтиЖелудь("КонсольноеПриложение");

	ПараметрыКоманды = Новый Массив();
	ПараметрыКоманды.Добавить("importing");
	ПараметрыКоманды.Добавить("--help");

	Попытка
		КонсольноеПриложение.Запустить(ПараметрыКоманды);
	Исключение
		// Некоторые реализации могут завершаться после вывода справки
	КонецПопытки;

	// Тогда — убеждаемся, что опции из набора зарегистрированы в команде.
	// ОписаниеКоманды() регистрирует opции. Если бы они не были зарегистрированы,
	// вызов --ibconnection ранее в других тестах бы уже упал.
	// Здесь дополнительно проверяем, что опции доступны через API команды.

	КомандаОбъект = Поделка.НайтиЖелудь("КомандаСНаборомОпций");
	Ожидаем.Что(КомандаОбъект).Заполнено();

КонецПроцедуры