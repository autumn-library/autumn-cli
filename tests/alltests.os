&Тест
Процедура НаборОпций_ОпцииНабораПередаютсяВКоманду() Экспорт
	// Дано

	Поделка = ПолучитьПоделку();
	Поделка.ЗапуститьПриложение();

	// Когда

	Команда = Поделка.НайтиЖелудь("КомандаСНаборомОпций");
	КонсольноеПриложение = Поделка.НайтиЖелудь("КонсольноеПриложение");

	ПараметрыКоманды = Новый Массив();
	ПараметрыКоманды.Добавить("importing");
	ПараметрыКоманды.Добавить("--ibconnection");
	ПараметрыКоманды.Добавить("/server/db");
	ПараметрыКоманды.Добавить("--v8version");
	ПараметрыКоманды.Добавить("8.3.20");
	ПараметрыКоманды.Добавить("/path/to/config.cf");

	КонсольноеПриложение.Запустить(ПараметрыКоманды);

	// Тогда

	Ожидаем.Что(Команда.Результат[0], "Аргумент PATH").Равно("/path/to/config.cf");
	Ожидаем.Что(Команда.Результат[1], "Опция из набора ibconnection").Равно("/server/db");
	Ожидаем.Что(Команда.Результат[2], "Опция из набора v8version").Равно("8.3.20");

КонецПроцедуры

